{
  "expo": {
    "name": "CoinInsight",
    "slug": "coininsight",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0F",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CoinInsight to use the camera to scan coins."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow CoinInsight to use Face ID to unlock your vault."
        }
      ],
      "expo-asset"
    ]
  }
}
